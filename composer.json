{
    "name": "stardent/smart-learning-tracker",
    "type": "project",
    "description": "Smart Learning Tracker backend built with Laravel API + Sanctum",
    "keywords": ["laravel", "api", "learning", "ai"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.9",
        "openai-php/client": "^0.8.3",
        "google/apiclient": "^2.15",
        "league/oauth2-client": "^2.9"
    },
    "require-dev": {
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0",
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "classmap": [
            "database/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
